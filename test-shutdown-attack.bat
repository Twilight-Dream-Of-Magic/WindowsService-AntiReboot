@echo off
chcp 65001 >nul 2>&1
title ShutdownGuard - 关机/重启攻击测试

echo.
echo ==========================================
echo   ShutdownGuard 防护测试脚本
echo   每次会尝试一种关机/重启方式，观察是否
echo   弹出密码框（有防护）或真的关/重启（无防护）
echo ==========================================
echo.
echo 【说明】防护靠在当前 cmd 里注入 hook 实现。
echo 服务会：① WMI 监听新进程，新 cmd 一出现就立即注入；② 每 5 秒再扫一轮。
echo 双击本 .bat 后稍等 1～2 秒再开始测试即可；若仍拦不住可多等几秒。
echo.
echo 每次测试用 30 秒倒计时，便于观察。
echo 测试结束后会自动执行 shutdown /a 取消，再按任意键进行下一项。
echo.
pause

:: ----------------------------------------------------------------------
:: 测试 1：shutdown /s 关机（30 秒后）
:: ----------------------------------------------------------------------
echo.
echo [测试 1/6] shutdown /s /t 30  （计划 30 秒后关机）
echo 预期：若防护生效，应弹出密码框；输入正确密码后才会真正关。
echo.
shutdown /s /t 30 /c "ShutdownGuardTest-1"
echo 已发起关机计划。请观察是否出现密码提示...
pause
shutdown /a
echo 已取消关机。按任意键进入下一项测试。
pause >nul

:: ----------------------------------------------------------------------
:: 测试 2：shutdown /r 重启（30 秒后）
:: ----------------------------------------------------------------------
echo.
echo [测试 2/6] shutdown /r /t 30  （计划 30 秒后重启）
echo 预期：若防护生效，应弹出密码框。
echo.
shutdown /r /t 30 /c "ShutdownGuardTest-2"
echo 已发起重启计划。请观察是否出现密码提示...
pause
shutdown /a
echo 已取消。按任意键进入下一项测试。
pause >nul

:: ----------------------------------------------------------------------
:: 测试 3：shutdown /s /t 0 立即关机（无倒计时）
:: ----------------------------------------------------------------------
echo.
echo [测试 3/6] shutdown /s /t 0  （立即关机，无倒计时）
echo 预期：若防护生效，应立刻弹出密码框并阻止关机。
echo 若无防护，机器会马上开始关机！
echo.
set /p "go3=确认执行此测试？输入 Y 回车继续: "
if /i "%go3%"=="Y" (
    shutdown /s /t 0
    echo 已发起立即关机。若看到此句且机器未关，说明被拦截。
    timeout /t 3
    shutdown /a
)
echo 按任意键进入下一项测试。
pause >nul

:: ----------------------------------------------------------------------
:: 测试 4：shutdown /r /t 0 立即重启
:: ----------------------------------------------------------------------
echo.
echo [测试 4/6] shutdown /r /t 0  （立即重启）
echo 预期：若防护生效，应立刻弹出密码框并阻止重启。
echo.
set /p "go4=确认执行此测试？输入 Y 回车继续: "
if /i "%go4%"=="Y" (
    shutdown /r /t 0
    echo 已发起立即重启。若看到此句且机器未重启，说明被拦截。
    timeout /t 3
    shutdown /a
)
echo 按任意键进入下一项测试。
pause >nul

:: ----------------------------------------------------------------------
:: 测试 5：PowerShell Restart-Computer（新进程，依赖看门狗及时注入）
:: ----------------------------------------------------------------------
echo.
echo [测试 5/6] PowerShell Restart-Computer -Force
echo 预期：若防护生效，应弹出密码框或阻止重启。
echo 说明：会启动新的 powershell.exe，MinGW 轮询模式约 400ms 扫一次，若仍漏拦可稍等几秒再按 Y。
echo.
set /p "go5=确认执行此测试？输入 Y 回车继续: "
if /i "%go5%"=="Y" (
    powershell -NoProfile -Command "Restart-Computer -Force"
    echo 已发起重启。若看到此句且机器未重启，说明被拦截。
    timeout /t 5
    shutdown /a
)
echo 按任意键进入下一项测试。
pause >nul

:: ----------------------------------------------------------------------
:: 测试 6：shutdown /h 休眠（若系统支持）
:: ----------------------------------------------------------------------
echo.
echo [测试 6/6] shutdown /h  （休眠）
echo 预期：若防护包含休眠，应弹出密码框；否则可能直接休眠。
echo.
set /p "go6=确认执行此测试？输入 Y 回车继续: "
if /i "%go6%"=="Y" (
    shutdown /h
    echo 已发起休眠。若看到此句且未休眠，说明被拦截。
    timeout /t 3
    shutdown /a
)
echo.
echo ==========================================
echo   全部测试结束
echo ==========================================
pause
